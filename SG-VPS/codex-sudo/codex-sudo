#!/usr/bin/env bash
set -euo pipefail

APP="codex-sudo"
VERSION="sg-strict-2026.06.12"

TARGET_USER="${CODEX_SUDO_USER:-codex}"
RULE_FILE="/etc/sudoers.d/90-${TARGET_USER}-temp-sudo"
BACKUP_BASE="/root/sg-backup/codex-sudo"
NO_COLOR="${NO_COLOR:-0}"

if [ -t 1 ] && [ "$NO_COLOR" != "1" ]; then
    RESET="\033[0m"
    BOLD="\033[1m"
    DIM="\033[2m"
    RED="\033[31m"
    GREEN="\033[32m"
    YELLOW="\033[33m"
    MAGENTA="\033[35m"
    CYAN="\033[36m"
    WHITE="\033[37m"
else
    RESET=""
    BOLD=""
    DIM=""
    RED=""
    GREEN=""
    YELLOW=""
    MAGENTA=""
    CYAN=""
    WHITE=""
fi

need_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}ERROR${RESET} 需要 root 权限运行。"
        echo -e "用法：${CYAN}sudo codex-sudo${RESET}"
        exit 1
    fi
}

validate_user() {
    if [[ ! "$TARGET_USER" =~ ^[a-z_][a-z0-9_-]*[$]?$ ]]; then
        echo -e "${RED}ERROR${RESET} 用户名不安全：$TARGET_USER"
        exit 1
    fi

    if ! getent passwd "$TARGET_USER" >/dev/null; then
        echo -e "${RED}ERROR${RESET} 用户不存在：$TARGET_USER"
        exit 1
    fi
}

make_backup_dir() {
    local ts
    ts="$(date '+%Y%m%d-%H%M%S')"
    local dir="${BACKUP_BASE}/${TARGET_USER}-${ts}"
    mkdir -p "$dir"
    echo "$dir"
}

grant_guard() {
    local target_uid
    target_uid="$(id -u "$TARGET_USER")"

    # 允许 root 直接授权。
    # 允许其他管理员 sudo 后授权。
    # 禁止目标用户自己通过 sudo 给自己创建/恢复 sudo 权限。
    if [ "${SUDO_USER:-}" = "$TARGET_USER" ] || [ "${SUDO_UID:-}" = "$target_uid" ]; then
        echo -e "${RED}${BOLD}拒绝：${TARGET_USER} 不能通过 sudo 给自己创建或恢复 sudo 权限。${RESET}"
        echo
        echo -e "${YELLOW}请切回 root 会话执行：${CYAN}codex-sudo on${YELLOW} 或 ${CYAN}codex-sudo pass${RESET}"
        echo -e "${DIM}当前 SUDO_USER=${SUDO_USER:-}, SUDO_UID=${SUDO_UID:-}${RESET}"
        exit 1
    fi
}

clear_sudo_cache() {
    sudo -H -u "$TARGET_USER" sudo -K 2>/dev/null || true
    sudo -H -u "$TARGET_USER" sudo -k 2>/dev/null || true
    rm -f "/run/sudo/ts/${TARGET_USER}" 2>/dev/null || true
}

sudo_l_output() {
    sudo -l -U "$TARGET_USER" 2>&1 || true
}

has_nopass_policy() {
    sudo_l_output | grep -qE 'NOPASSWD:[[:space:]]*ALL|NOPASSWD'
}

has_any_sudo_policy() {
    sudo_l_output | grep -qE 'may run the following commands|NOPASSWD|PASSWD|\(ALL'
}

fresh_can_nopass() {
    clear_sudo_cache
    sudo -H -u "$TARGET_USER" sudo -n true >/dev/null 2>&1
}

our_mode() {
    if [ ! -f "$RULE_FILE" ]; then
        echo "OFF"
    elif grep -q "NOPASSWD" "$RULE_FILE"; then
        echo "NOPASS"
    elif grep -q "PASSWD" "$RULE_FILE" || grep -q "timestamp_timeout" "$RULE_FILE"; then
        echo "PASS"
    else
        echo "UNKNOWN"
    fi
}

security_state() {
    if fresh_can_nopass; then
        echo "DANGER_NOPASS"
    elif has_any_sudo_policy; then
        echo "WARN_PASS"
    else
        echo "SAFE_OFF"
    fi
}

state_line() {
    case "$(security_state)" in
        SAFE_OFF)
            echo -e "${GREEN}● 安全：sudo 已关闭${RESET}"
            ;;
        WARN_PASS)
            echo -e "${YELLOW}● 警告：存在密码 sudo 授权${RESET}"
            ;;
        DANGER_NOPASS)
            echo -e "${RED}● 危险：存在免密 root 提权${RESET}"
            ;;
    esac
}

our_line() {
    case "$(our_mode)" in
        OFF)
            echo -e "${GREEN}本脚本规则：已关闭${RESET}"
            ;;
        PASS)
            echo -e "${YELLOW}本脚本规则：密码 sudo${RESET}"
            ;;
        NOPASS)
            echo -e "${RED}本脚本规则：免密 sudo${RESET}"
            ;;
        *)
            echo -e "${RED}本脚本规则：未知${RESET}"
            ;;
    esac
}

nopass_line() {
    if fresh_can_nopass; then
        echo -e "${RED}可免密提权到 root${RESET}"
    else
        echo -e "${GREEN}不可免密提权${RESET}"
    fi
}

logo() {
    echo -e "${MAGENTA}${BOLD}"
    cat <<'LOGO'
   ███████╗ ██████╗      ██████╗ ██████╗ ██████╗ ███████╗██╗  ██╗
   ██╔════╝██╔════╝     ██╔════╝██╔═══██╗██╔══██╗██╔════╝╚██╗██╔╝
   ███████╗██║  ███╗    ██║     ██║   ██║██║  ██║█████╗   ╚███╔╝
   ╚════██║██║   ██║    ██║     ██║   ██║██║  ██║██╔══╝   ██╔██╗
   ███████║╚██████╔╝    ╚██████╗╚██████╔╝██████╔╝███████╗██╔╝ ██╗
   ╚══════╝ ╚═════╝      ╚═════╝ ╚═════╝ ╚═════╝ ╚══════╝╚═╝  ╚═╝
LOGO
    echo -e "${RESET}${CYAN}${BOLD}              SUDO 权限控制面板 · 严格版${RESET}"
    echo
}

panel() {
    clear 2>/dev/null || true
    logo

    echo -e "${DIM}────────────────────────────────────────────────────────${RESET}"
    echo -e "${WHITE}${BOLD}权限对象${RESET}   ${CYAN}${TARGET_USER}${RESET}"
    echo -e "${WHITE}${BOLD}控制文件${RESET}   ${DIM}${RULE_FILE}${RESET}"
    echo -e "${WHITE}${BOLD}脚本状态${RESET}   $(our_line)"
    echo -e "${WHITE}${BOLD}实际状态${RESET}   $(state_line)"
    echo -e "${WHITE}${BOLD}免密检测${RESET}   $(nopass_line)"
    echo -e "${WHITE}${BOLD}当前时间${RESET}   ${DIM}$(date '+%Y-%m-%d %H:%M:%S')${RESET}"
    echo -e "${DIM}────────────────────────────────────────────────────────${RESET}"
    echo

    echo -e "${GREEN}${BOLD}请选择操作${RESET}"
    echo -e "  ${RED}[1]${RESET} 开启免密 sudo                 ${RED}危险：codex≈root${RESET}"
    echo -e "  ${GREEN}[2]${RESET} 严格撤销 sudo                ${GREEN}推荐：清规则 + 清缓存 + 查残留${RESET}"
    echo -e "  ${YELLOW}[3]${RESET} 密码 sudo：每次都输密码      timestamp_timeout=0"
    echo -e "  ${YELLOW}[4]${RESET} 密码 sudo：缓存 1 分钟       timestamp_timeout=1"
    echo -e "  ${YELLOW}[5]${RESET} 密码 sudo：缓存 5 分钟       timestamp_timeout=5"
    echo -e "  ${YELLOW}[6]${RESET} 密码 sudo：自定义分钟"
    echo -e "  ${CYAN}[7]${RESET} 安全审计"
    echo -e "  ${CYAN}[8]${RESET} 进入 codex 安全 shell"
    echo -e "  ${CYAN}[9]${RESET} 通过 codex 的 sudo 执行命令"
    echo -e "  ${CYAN}[0]${RESET} 退出"
    echo

    echo -e "${YELLOW}${BOLD}说明${RESET}"
    echo -e "  ${DIM}sudo 原生按“分钟”缓存，不按“次数”缓存。每次都输密码请选 [3]。${RESET}"
    echo
}

pause() {
    echo
    read -r -p "按 Enter 返回菜单..." _
}

validate_timeout() {
    local v="$1"
    if [[ ! "$v" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
        echo -e "${RED}ERROR${RESET} 缓存分钟必须是数字，例如 0、1、2.5、5"
        exit 1
    fi
}

write_rule_nopass() {
    grant_guard
    local tmp
    tmp="$(mktemp)"

    cat >"$tmp" <<RULE
# SG temporary sudo rule for ${TARGET_USER}
# DANGER: NOPASSWD means ${TARGET_USER} can become root without password.
${TARGET_USER} ALL=(ALL:ALL) NOPASSWD: ALL
RULE

    chown root:root "$tmp"
    chmod 0440 "$tmp"

    if ! visudo -cf "$tmp" >/dev/null; then
        rm -f "$tmp"
        echo -e "${RED}ERROR${RESET} sudoers 语法检查失败，未写入。"
        exit 1
    fi

    install -o root -g root -m 0440 "$tmp" "$RULE_FILE"
    rm -f "$tmp"
}

write_rule_pass() {
    grant_guard
    local timeout="$1"
    validate_timeout "$timeout"

    local tmp
    tmp="$(mktemp)"

    cat >"$tmp" <<RULE
# SG controlled sudo rule for ${TARGET_USER}
# Password sudo mode. timestamp_timeout controls sudo credential cache in minutes.
Defaults:${TARGET_USER} timestamp_timeout=${timeout}
${TARGET_USER} ALL=(ALL:ALL) PASSWD: ALL
RULE

    chown root:root "$tmp"
    chmod 0440 "$tmp"

    if ! visudo -cf "$tmp" >/dev/null; then
        rm -f "$tmp"
        echo -e "${RED}ERROR${RESET} sudoers 语法检查失败，未写入。"
        exit 1
    fi

    install -o root -g root -m 0440 "$tmp" "$RULE_FILE"
    rm -f "$tmp"
}

remove_admin_groups() {
    gpasswd -d "$TARGET_USER" sudo 2>/dev/null || true
    gpasswd -d "$TARGET_USER" admin 2>/dev/null || true
    gpasswd -d "$TARGET_USER" wheel 2>/dev/null || true
}

strict_revoke() {
    local backup_dir
    backup_dir="$(make_backup_dir)"

    echo -e "${CYAN}${BOLD}开始严格撤销 ${TARGET_USER} sudo...${RESET}"
    echo -e "${DIM}备份目录：${backup_dir}${RESET}"
    echo

    if [ -f "$RULE_FILE" ]; then
        cp -a "$RULE_FILE" "$backup_dir/"
        rm -f "$RULE_FILE"
        echo -e "${GREEN}已删除本脚本规则：${RULE_FILE}${RESET}"
    fi

    local known_session="/etc/sudoers.d/${TARGET_USER}-${TARGET_USER}-session"
    if [ -f "$known_session" ]; then
        cp -a "$known_session" "$backup_dir/"
        rm -f "$known_session"
        echo -e "${GREEN}已删除 Codex session 免密规则：${known_session}${RESET}"
    fi

    shopt -s nullglob
    local f base
    for f in /etc/sudoers.d/*; do
        [ -f "$f" ] || continue
        base="$(basename "$f")"

        # 删除文件名包含目标用户，且内容存在 NOPASSWD 的 sudoers.d 文件
        if [[ "$base" == *"$TARGET_USER"* ]] && grep -qi "NOPASSWD" "$f"; then
            cp -a "$f" "$backup_dir/"
            rm -f "$f"
            echo -e "${GREEN}已删除疑似 ${TARGET_USER} 免密规则文件：${f}${RESET}"
            continue
        fi

        # 对于文件名不含用户，但内容直接写了用户 + NOPASSWD 的文件，只报警不自动删，避免误伤共享规则
        if grep -Eiq "(^|[[:space:]])${TARGET_USER}([[:space:]]|$).*NOPASSWD|NOPASSWD.*(^|[[:space:]])${TARGET_USER}([[:space:]]|$)" "$f"; then
            echo -e "${RED}发现共享 sudoers 文件里含 ${TARGET_USER} NOPASSWD，请手动检查：${f}${RESET}"
            grep -nEi "${TARGET_USER}|NOPASSWD" "$f" || true
        fi
    done

    remove_admin_groups
    clear_sudo_cache

    if visudo -c >/dev/null; then
        echo -e "${GREEN}sudoers 语法检查通过。${RESET}"
    else
        echo -e "${RED}sudoers 语法检查失败，请立刻检查。${RESET}"
        exit 1
    fi

    echo
    echo -e "${CYAN}${BOLD}撤销后审计：${RESET}"
    audit_core

    if fresh_can_nopass; then
        echo
        echo -e "${RED}${BOLD}警告：${TARGET_USER} 仍然可以免密提权到 root！${RESET}"
        echo -e "${RED}请查看上面的 sudo -l 和 grep 结果，说明还有其他规则来源。${RESET}"
    else
        echo
        echo -e "${GREEN}${BOLD}完成：${TARGET_USER} 已不能免密提权。${RESET}"
    fi
}

audit_core() {
    echo -e "${WHITE}${BOLD}用户与组：${RESET}"
    id "$TARGET_USER" || true
    echo

    echo -e "${WHITE}${BOLD}sudo -l -U ${TARGET_USER}：${RESET}"
    sudo_l_output
    echo

    echo -e "${WHITE}${BOLD}sudoers 中相关规则：${RESET}"
    grep -RInE "${TARGET_USER}|%sudo|%admin|%wheel|NOPASSWD" /etc/sudoers /etc/sudoers.d 2>/dev/null || true
    echo

    echo -e "${WHITE}${BOLD}清缓存后免密测试：${RESET}"
    if fresh_can_nopass; then
        echo -e "${RED}FAIL：${TARGET_USER} 仍可免密 sudo 到 root${RESET}"
    else
        echo -e "${GREEN}PASS：${TARGET_USER} 不可免密 sudo 到 root${RESET}"
    fi
}

action_on() {
    write_rule_nopass
    clear_sudo_cache
    panel
    echo -e "${RED}${BOLD}已开启${RESET} ${TARGET_USER} 免密 sudo。"
    echo -e "${RED}注意：此时 ${TARGET_USER} 基本等价于 root。用完请选 [2] 严格撤销。${RESET}"
    pause
}

action_off() {
    panel
    strict_revoke
    pause
}

action_pass_timeout() {
    local timeout="$1"
    write_rule_pass "$timeout"
    clear_sudo_cache
    panel
    echo -e "${YELLOW}${BOLD}已开启${RESET} ${TARGET_USER} 密码 sudo。"
    echo -e "${YELLOW}sudo 密码缓存时间：${timeout} 分钟。${RESET}"
    if [ "$timeout" = "0" ]; then
        echo -e "${GREEN}严格模式：每次 sudo 都需要重新输入密码。${RESET}"
    fi
    echo
    echo -e "${DIM}提醒：如果 ${TARGET_USER} 没有密码，请先执行：passwd ${TARGET_USER}${RESET}"
    pause
}

action_custom_pass() {
    panel
    read -r -p "请输入 sudo 密码缓存分钟数，例如 0、1、2.5、5、15： " timeout
    if [ -z "$timeout" ]; then
        echo -e "${YELLOW}未输入，已取消。${RESET}"
        pause
        return
    fi
    validate_timeout "$timeout"
    action_pass_timeout "$timeout"
}

action_audit() {
    panel
    echo -e "${CYAN}${BOLD}安全审计${RESET}"
    audit_core
    pause
}

action_shell() {
    clear 2>/dev/null || true
    echo -e "${CYAN}${BOLD}正在进入 ${TARGET_USER} 安全 shell...${RESET}"
    echo -e "${DIM}不会读取 .profile / .bashrc。退出请输入 exit。${RESET}"
    echo
    exec sudo -H -u "$TARGET_USER" /bin/bash --noprofile --norc
}

action_run() {
    panel
    echo -e "${CYAN}${BOLD}通过 ${TARGET_USER} 的 sudo 执行命令${RESET}"
    echo -e "${DIM}如果是密码 sudo，可能需要交互输入密码；如果是免密 sudo，会直接执行。${RESET}"
    echo
    read -r -p "请输入命令： " USER_CMD

    if [ -z "$USER_CMD" ]; then
        echo -e "${YELLOW}未输入命令，已取消。${RESET}"
        pause
        return
    fi

    echo
    echo -e "${DIM}执行：sudo -H -u ${TARGET_USER} sudo /bin/bash -lc \"$USER_CMD\"${RESET}"
    echo

    if sudo -H -u "$TARGET_USER" sudo /bin/bash -lc "$USER_CMD"; then
        echo
        echo -e "${GREEN}命令执行完成。${RESET}"
    else
        echo
        echo -e "${RED}命令执行失败。${RESET}"
    fi

    pause
}

menu_loop() {
    while true; do
        panel
        printf "%b" "${CYAN}${BOLD}请输入选项 [0-9]：${RESET}"
        read -r choice

        case "$choice" in
            1) action_on ;;
            2) action_off ;;
            3) action_pass_timeout 0 ;;
            4) action_pass_timeout 1 ;;
            5) action_pass_timeout 5 ;;
            6) action_custom_pass ;;
            7) action_audit ;;
            8) action_shell ;;
            9) action_run ;;
            0|q|Q|exit|quit)
                clear 2>/dev/null || true
                echo -e "${GREEN}已退出 SG CODEX SUDO 面板。${RESET}"
                exit 0
                ;;
            "")
                continue
                ;;
            *)
                echo -e "${RED}无效选项：$choice${RESET}"
                sleep 1
                ;;
        esac
    done
}

usage() {
    cat <<USAGE
SG CODEX SUDO - 严格版

用法:
  codex-sudo                 打开数字菜单
  codex-sudo status          显示状态面板
  codex-sudo on              开启免密 sudo
  codex-sudo off             严格撤销 sudo
  codex-sudo pass            开启密码 sudo，每次都输密码
  codex-sudo pass 5          开启密码 sudo，缓存 5 分钟
  codex-sudo audit           安全审计
  codex-sudo shell           进入 codex 安全 shell

环境变量:
  CODEX_SUDO_USER=xxx codex-sudo

版本:
  $APP $VERSION
USAGE
}

need_root
validate_user

case "${1:-menu}" in
    menu) menu_loop ;;
    status|panel) panel ;;
    on|enable|nopass) write_rule_nopass; clear_sudo_cache; panel ;;
    off|disable|revoke) strict_revoke ;;
    pass|password)
        if [ -n "${2:-}" ]; then
            validate_timeout "$2"
            write_rule_pass "$2"
        else
            write_rule_pass 0
        fi
        clear_sudo_cache
        panel
        ;;
    audit|check) audit_core ;;
    shell) action_shell ;;
    help|-h|--help) usage ;;
    version|-V|--version) echo "$APP $VERSION" ;;
    *)
        echo -e "${RED}未知命令：$1${RESET}"
        echo
        usage
        exit 1
        ;;
esac
